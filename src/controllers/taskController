const renderTasksPage = (res, options = {}) => {
  const {
    gameName = "",
    tagLine = "",
    accountData = null,
    rawJson = null,
    error = null,
  } = options;

  return res.render("tasks", {
    gameName,
    tagLine,
    accountData,
    rawJson,
    error,
  });
};

exports.renderTasks = async (req, res) => {
  const gameName = typeof req.query.gameName === "string" ? req.query.gameName.trim() : "";
  const tagLine = typeof req.query.tagLine === "string" ? req.query.tagLine.trim() : "";

  if (!gameName && !tagLine) {
    return renderTasksPage(res);
  }

  if (!gameName || !tagLine) {
    return renderTasksPage(res, {
      gameName,
      tagLine,
      error: "Please enter both Riot ID and Tag.",
    });
  }

  try {
    const response = await fetch(
      `https://api.henrikdev.xyz/valorant/v1/account/${encodeURIComponent(gameName)}/${encodeURIComponent(tagLine)}`,
      {
        headers: {
          Authorization: process.env.VAL_API_KEY,
        },
      }
    );

    const text = await response.text();
    let parsedBody = null;

    try {
      parsedBody = JSON.parse(text);
    } catch {
      parsedBody = null;
    }

    if (!response.ok) {
      return renderTasksPage(res, {
        gameName,
        tagLine,
        rawJson: parsedBody || text,
        error:
          (parsedBody && parsedBody.errors && parsedBody.errors[0] && parsedBody.errors[0].message) ||
          "API request failed",
      });
    }

    return renderTasksPage(res, {
      gameName,
      tagLine,
      accountData: parsedBody ? parsedBody.data : null,
      rawJson: parsedBody || text,
    });
  } catch (err) {
    console.error("catch error:", err);
    return renderTasksPage(res, {
      gameName,
      tagLine,
      error: err.message || "Server error",
    });
  }
};
