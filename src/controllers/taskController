const User = require("../models/User");

const normalizeStoredProfile = (profile) => {
  if (!profile) {
    return null;
  }

  const lastUpdate =
    profile.lastUpdate instanceof Date
      ? profile.lastUpdate
      : profile.lastUpdate
        ? new Date(profile.lastUpdate)
        : null;

  return {
    name: profile.gameName,
    tag: profile.tagLine,
    puuid: profile.puuid,
    region: profile.region,
    account_level: profile.accountLevel,
    card: profile.card || null,
    last_update: lastUpdate && !Number.isNaN(lastUpdate.getTime()) ? lastUpdate.toISOString() : null,
    last_update_raw: profile.lastUpdateRaw ?? null,
  };
};

const parseOptionalDate = (value) => {
  if (!value) {
    return null;
  }

  const parsed = new Date(value);
  return Number.isNaN(parsed.getTime()) ? null : parsed;
};

const renderTasksPage = (res, options = {}) => {
  const {
    gameName = "",
    tagLine = "",
    accountData = null,
    rawJson = null,
    error = null,
    success = null,
  } = options;

  return res.render("tasks", {
    gameName,
    tagLine,
    accountData,
    rawJson,
    error,
    success,
  });
};

const fetchValorantAccount = async (gameName, tagLine) => {
  const response = await fetch(
    `https://api.henrikdev.xyz/valorant/v1/account/${encodeURIComponent(gameName)}/${encodeURIComponent(tagLine)}`,
    {
      headers: {
        Authorization: process.env.VAL_API_KEY,
      },
    }
  );

  const text = await response.text();
  let parsedBody = null;

  try {
    parsedBody = JSON.parse(text);
  } catch {
    parsedBody = null;
  }

  if (!response.ok) {
    const errorMessage =
      (parsedBody && parsedBody.errors && parsedBody.errors[0] && parsedBody.errors[0].message) ||
      "API request failed";

    const error = new Error(errorMessage);
    error.rawJson = parsedBody || text;
    throw error;
  }

  return {
    accountData: parsedBody ? parsedBody.data : null,
    rawJson: parsedBody || text,
  };
};

exports.renderTasks = async (req, res) => {
  try {
    const user = await User.findById(req.session.userId).lean();

    if (!user) {
      return renderTasksPage(res, {
        error: "User not found.",
      });
    }

    const storedProfile = normalizeStoredProfile(user.valorantProfile);

    return renderTasksPage(res, {
      gameName: user.valorantProfile?.gameName || "",
      tagLine: user.valorantProfile?.tagLine || "",
      accountData: storedProfile,
      rawJson: user.valorantProfile || null,
    });
  } catch (err) {
    console.error("renderTasks error:", err);
    return renderTasksPage(res, {
      error: err.message || "Server error",
    });
  }
};

exports.saveTasksProfile = async (req, res) => {
  const gameName = typeof req.body.gameName === "string" ? req.body.gameName.trim() : "";
  const tagLine = typeof req.body.tagLine === "string" ? req.body.tagLine.trim() : "";

  if (!gameName || !tagLine) {
    return renderTasksPage(res, {
      gameName,
      tagLine,
      error: "Please enter both Riot ID and Tag.",
    });
  }

  try {
    const { accountData, rawJson } = await fetchValorantAccount(gameName, tagLine);

    if (!accountData || !accountData.puuid || !accountData.region) {
      return renderTasksPage(res, {
        gameName,
        tagLine,
        rawJson,
        error: "The API response did not include the required account fields.",
      });
    }

    const user = await User.findById(req.session.userId);

    if (!user) {
      return renderTasksPage(res, {
        gameName,
        tagLine,
        error: "User not found.",
      });
    }

    user.valorantProfile = {
      gameName: accountData.name || gameName,
      tagLine: accountData.tag || tagLine,
      puuid: accountData.puuid,
      region: accountData.region,
      accountLevel: accountData.account_level ?? null,
      card: accountData.card
        ? {
            small: accountData.card.small || "",
            large: accountData.card.large || "",
            wide: accountData.card.wide || "",
            id: accountData.card.id || "",
          }
        : undefined,
      lastUpdate: parseOptionalDate(accountData.last_update),
      lastUpdateRaw: accountData.last_update_raw ?? null,
    };

    await user.save();

    return renderTasksPage(res, {
      gameName: user.valorantProfile.gameName,
      tagLine: user.valorantProfile.tagLine,
      accountData: normalizeStoredProfile(user.valorantProfile),
      rawJson: user.valorantProfile,
      success: "Account data was fetched and saved to your user profile.",
    });
  } catch (err) {
    console.error("saveTasksProfile error:", err);

    return renderTasksPage(res, {
      gameName,
      tagLine,
      rawJson: err.rawJson || null,
      error:
        err && err.code === 11000
          ? "This Riot account is already saved by another user."
          : err.message || "Server error",
    });
  }
};
