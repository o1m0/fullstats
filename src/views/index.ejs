<%- include('partials/header', { title: 'Home', css: 'home.css', isLoggedIn }) %>
<%- include('partials/nav', { isLoggedIn }) %>
<main class="simple-page">
    <div class="container site-container">
        <section class="card shadow-sm border-0 simple-hero">
            <p class="simple-eyebrow">FullStats</p>
            <h1 class="simple-title">Simple team admin</h1>
            <p class="simple-text">
                This is the top page for the project. Keep it minimal and use it as an entry point to login or open the task screen.
            </p>
            <div class="d-flex flex-wrap gap-2">
                <% if (isLoggedIn) { %>
                    <a href="/tasks" class="btn btn-dark simple-button">Open Tasks</a>
                <% } else { %>
                    <a href="/login" class="btn btn-dark simple-button">Login</a>
                    <a href="/register" class="btn btn-outline-secondary simple-button">Register</a>
                <% } %>
            </div>
        </section>

        <section class="row g-3 simple-grid">
            <div class="col-md-4">
            <article class="card h-100 shadow-sm border-0 simple-card">
                <h2>Home</h2>
                <p>Use this page as a simple landing page without decorative sections.</p>
            </article>
            </div>
            <div class="col-md-4">
            <article class="card h-100 shadow-sm border-0 simple-card">
                <h2>Login</h2>
                <p>Members can sign in and move to the task management page.</p>
            </article>
            </div>
            <div class="col-md-4">
            <article class="card h-100 shadow-sm border-0 simple-card">
                <h2>Tasks</h2>
                <p>The admin page is separated into form, summary, and JSON blocks.</p>
            </article>
            </div>
        </section>
    </div>
</main>
<%- include('partials/footer', { isLoggedIn }) %>
