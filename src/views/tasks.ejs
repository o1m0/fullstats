<%- include('partials/header', { title: 'Tasks', css: 'tasks.css', isLoggedIn }) %>
<%- include('partials/nav', { isLoggedIn }) %>
<%
    const account = accountData || null;
    const rawJsonText = rawJson ? JSON.stringify(rawJson, null, 2) : "";
    const cardImage = account && account.card && (account.card.wide || account.card.large || account.card.small);
    const summaryItems = [
        { label: 'Riot ID', value: account ? (account.name || gameName || '-') : (gameName || '-') },
        { label: 'Tag', value: account ? ('#' + (account.tag || tagLine || '-')) : (tagLine ? '#' + tagLine : '-') },
        { label: 'Region', value: account && account.region ? account.region : '-' },
        { label: 'Account Level', value: account && account.account_level != null ? account.account_level : '-' },
        { label: 'Last Updated', value: account && account.last_update ? account.last_update : '-' },
        { label: 'PUUID', value: account && account.puuid ? account.puuid : '-' },
        { label: 'last_update_raw', value: account && account.last_update_raw != null ? account.last_update_raw : '-' }
    ];
%>
<main class="simple-page tasks-page">
    <div class="container site-container">
        <section class="tasks-shell">
            <header class="card shadow-sm border-0 simple-hero tasks-hero">
                <div>
                    <p class="simple-eyebrow">Tasks</p>
                    <h1 class="simple-title">Task Management</h1>
                    <p class="simple-text">
                        Search a Riot account and review the response in a simple admin layout.
                    </p>
                </div>
            </header>

            <section class="row g-3 tasks-layout">
                <aside class="col-lg-4 tasks-sidebar">
                    <article class="card shadow-sm border-0 tasks-panel">
                        <div class="tasks-panel-head">
                            <p class="tasks-panel-label">Search</p>
                            <h2 class="tasks-panel-title">Account Search</h2>
                        </div>

                        <form class="vstack gap-3 tasks-form" action="/tasks" method="GET">
                            <div>
                                <label for="gameName" class="form-label tasks-label">Riot ID</label>
                                <input
                                    id="gameName"
                                    name="gameName"
                                    type="text"
                                    class="form-control tasks-input"
                                    value="<%= gameName || '' %>"
                                    placeholder="PlayerName"
                                    required
                                >
                            </div>

                            <div>
                                <label for="tagLine" class="form-label tasks-label">Tag</label>
                                <input
                                    id="tagLine"
                                    name="tagLine"
                                    type="text"
                                    class="form-control tasks-input"
                                    value="<%= tagLine || '' %>"
                                    placeholder="TagLine"
                                    required
                                >
                            </div>

                            <div class="tasks-form-actions d-grid">
                                <button type="submit" class="btn btn-dark simple-button">Search</button>
                            </div>
                        </form>
                    </article>

                    <article class="card shadow-sm border-0 tasks-panel">
                        <div class="tasks-panel-head">
                            <p class="tasks-panel-label">Notes</p>
                            <h2 class="tasks-panel-title">Editing Notes</h2>
                        </div>

                        <ul class="tasks-note-list">
                            <li>The search form, summary, and raw JSON are separated into individual panels.</li>
                            <li>The layout follows the same minimal style as the other pages.</li>
                            <li>The summary uses the `summaryItems` array, making fields easy to add or remove.</li>
                        </ul>
                    </article>
                </aside>

                <div class="col-lg-8 tasks-main">
                    <article class="card shadow-sm border-0 tasks-panel">
                        <div class="tasks-panel-head">
                            <p class="tasks-panel-label">Overview</p>
                            <h2 class="tasks-panel-title">Result Summary</h2>
                        </div>

                        <% if (error) { %>
                            <div class="alert alert-danger tasks-alert tasks-alert-error">
                                <strong>Error</strong>
                                <p><%= error %></p>
                            </div>
                        <% } else if (!account) { %>
                            <div class="alert alert-secondary tasks-alert">
                                <strong>Ready</strong>
                                <p>Enter Riot ID and Tag to display the account summary here.</p>
                            </div>
                        <% } %>

                        <div class="row g-3 align-items-start tasks-summary">
                            <div class="col-lg-4 tasks-summary-media">
                                <% if (cardImage) { %>
                                    <img src="<%= cardImage %>" alt="Player card preview" class="tasks-card-image">
                                <% } else { %>
                                    <div class="tasks-card-placeholder">No Image</div>
                                <% } %>
                            </div>

                            <div class="col-lg-8 tasks-summary-content">
                                <div class="tasks-identity">
                                    <p class="tasks-identity-label">Account</p>
                                    <h3 class="tasks-identity-name"><%= account ? (account.name || gameName) : 'Account Preview' %></h3>
                                    <p class="tasks-identity-tag"><%= account ? ('#' + (account.tag || tagLine || '-')) : '#TagLine' %></p>
                                </div>

                                <div class="row g-3 tasks-info-grid">
                                    <% summaryItems.forEach((item) => { %>
                                        <div class="col-md-6">
                                        <div class="tasks-info-item">
                                            <span><%= item.label %></span>
                                            <strong><%= item.value %></strong>
                                        </div>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                    </article>

                    <article class="card shadow-sm border-0 tasks-panel">
                        <div class="tasks-panel-head">
                            <p class="tasks-panel-label">Raw Data</p>
                            <h2 class="tasks-panel-title">JSON Details</h2>
                        </div>

                        <% if (rawJsonText) { %>
                            <pre class="tasks-code"><%= rawJsonText %></pre>
                        <% } else { %>
                            <div class="tasks-empty">
                                The API response JSON will appear here.
                            </div>
                        <% } %>
                    </article>
                </div>
            </section>
        </section>
    </div>
</main>
<%- include('partials/footer', { isLoggedIn }) %>
