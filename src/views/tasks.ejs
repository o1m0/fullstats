<%- include('partials/header', { title: 'Tasks', css: 'tasks.css', isLoggedIn }) %>
<%- include('partials/nav', { isLoggedIn }) %>
<%
    const account = accountData || null;
    const rawJsonText = rawJson ? JSON.stringify(rawJson, null, 2) : "";
    const cardImage = account && account.card && (account.card.wide || account.card.large || account.card.small);
%>
<main class="tasks-page tasks-architect-page">
    <div class="container site-container">
        <section class="tasks-architect-shell">
            <section class="tasks-architect-hero">
                <div class="tasks-architect-copy">
                    <p class="tasks-architect-lead">Workspace</p>
                    <h1 class="tasks-architect-title">Task Overview</h1>
                    <p class="tasks-architect-text">
                        Search a Riot account and review the returned JSON without leaving this page.
                    </p>
                </div>

                <div class="tasks-architect-actions">
                    <a href="/" class="btn tasks-architect-button is-secondary">Home</a>
                    <% if (isLoggedIn) { %>
                        <form action="/logout" method="POST" class="tasks-architect-inline-form">
                            <button type="submit" class="btn tasks-architect-button is-primary">Logout</button>
                        </form>
                    <% } else { %>
                        <a href="/login" class="btn tasks-architect-button is-primary">Login</a>
                    <% } %>
                </div>
            </section>

            <section class="tasks-architect-metrics">
                <article class="tasks-architect-metric">
                    <span>Members</span>
                    <strong>05</strong>
                </article>
                <article class="tasks-architect-metric">
                    <span>Open Tasks</span>
                    <strong>12</strong>
                </article>
                <article class="tasks-architect-metric">
                    <span>Ready Slots</span>
                    <strong>08</strong>
                </article>
                <article class="tasks-architect-metric">
                    <span>Next Match</span>
                    <strong>19:30</strong>
                </article>
            </section>

            <section class="tasks-architect-grid tasks-architect-grid-account">
                <article class="tasks-architect-panel">
                    <div class="tasks-architect-panel-head">
                        <span>Lookup</span>
                        <strong>Riot Account</strong>
                    </div>

                    <form class="tasks-account-form" action="/tasks" method="GET">
                        <div class="tasks-account-field">
                            <label for="gameName" class="tasks-account-label">Riot ID</label>
                            <input id="gameName" name="gameName" type="text" class="form-control tasks-account-input" value="<%= gameName || '' %>" placeholder="PlayerName" required>
                        </div>
                        <div class="tasks-account-field">
                            <label for="tagLine" class="tasks-account-label">Tag</label>
                            <input id="tagLine" name="tagLine" type="text" class="form-control tasks-account-input" value="<%= tagLine || '' %>" placeholder="TagLine" required>
                        </div>
                        <button type="submit" class="btn tasks-architect-button is-primary">Search</button>
                    </form>
                </article>

                <article class="tasks-architect-panel tasks-architect-panel-wide">
                    <div class="tasks-architect-panel-head">
                        <span>Result</span>
                        <strong>Account Preview</strong>
                    </div>

                    <% if (error) { %>
                        <div class="tasks-account-preview">
                            <div class="tasks-account-detail">
                                <span>Error</span>
                                <strong><%= error %></strong>
                            </div>
                            <% if (rawJsonText) { %>
                                <div class="tasks-account-json">
                                    <span class="tasks-account-json-label">Raw JSON</span>
                                    <pre class="tasks-account-json-body"><%= rawJsonText %></pre>
                                </div>
                            <% } %>
                        </div>
                    <% } else if (account) { %>
                        <div class="tasks-account-preview">
                            <div class="tasks-account-card">
                                <div class="tasks-account-card-media">
                                    <% if (cardImage) { %>
                                        <img src="<%= cardImage %>" alt="Player card preview" class="tasks-account-card-image">
                                    <% } else { %>
                                        <div class="tasks-account-card-image"></div>
                                    <% } %>
                                </div>
                                <div class="tasks-account-card-body">
                                    <p class="tasks-account-caption">Account</p>
                                    <h2 class="tasks-account-name"><%= account.name || gameName %></h2>
                                    <p class="tasks-account-tag">#<%= account.tag || tagLine %></p>
                                    <div class="tasks-account-meta">
                                        <div><span>Region</span><strong><%= account.region || "-" %></strong></div>
                                        <div><span>Level</span><strong><%= account.account_level ?? "-" %></strong></div>
                                        <div><span>Updated</span><strong><%= account.last_update || "-" %></strong></div>
                                    </div>
                                </div>
                            </div>

                            <div class="tasks-account-details">
                                <div class="tasks-account-detail">
                                    <span>PUUID</span>
                                    <strong><%= account.puuid || "-" %></strong>
                                </div>
                                <div class="tasks-account-detail">
                                    <span>last_update_raw</span>
                                    <strong><%= account.last_update_raw ?? "-" %></strong>
                                </div>
                            </div>

                            <div class="tasks-account-json">
                                <span class="tasks-account-json-label">Raw JSON</span>
                                <pre class="tasks-account-json-body"><%= rawJsonText %></pre>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="tasks-account-preview">
                            <div class="tasks-account-detail">
                                <span>Ready</span>
                                <strong>Enter Riot ID and Tag to show the account result here.</strong>
                            </div>
                        </div>
                    <% } %>
                </article>
            </section>

            <section class="tasks-architect-grid">
                <article class="tasks-architect-panel tasks-architect-panel-wide">
                    <div class="tasks-architect-panel-head">
                        <span>01</span>
                        <strong>Current Workflow</strong>
                    </div>
                    <div class="tasks-architect-list">
                        <div class="tasks-architect-item">
                            <strong>Availability Check</strong>
                            <p>Use the search panel to pull an account snapshot and inspect the response.</p>
                        </div>
                        <div class="tasks-architect-item">
                            <strong>Role Assignment</strong>
                            <p>Keep the account card visible while comparing region, level, and update time.</p>
                        </div>
                        <div class="tasks-architect-item">
                            <strong>Task Queue Review</strong>
                            <p>Use the raw JSON panel when you need fields that are not shown in the summary card.</p>
                        </div>
                    </div>
                </article>

                <article class="tasks-architect-panel">
                    <div class="tasks-architect-panel-head">
                        <span>02</span>
                        <strong>Status</strong>
                    </div>
                    <div class="tasks-architect-stack">
                        <div class="tasks-architect-row"><span>Lineup</span><strong>Ready</strong></div>
                        <div class="tasks-architect-row"><span>Roles</span><strong>Stable</strong></div>
                        <div class="tasks-architect-row"><span>Maps</span><strong>Updating</strong></div>
                    </div>
                </article>

                <article class="tasks-architect-panel">
                    <div class="tasks-architect-panel-head">
                        <span>03</span>
                        <strong>Sections</strong>
                    </div>
                    <div class="tasks-architect-sections">
                        <div>Availability Board</div>
                        <div>Role Management</div>
                        <div>Task Queue</div>
                        <div>Session Notes</div>
                    </div>
                </article>
            </section>
        </section>
    </div>
</main>
<%- include('partials/footer', { isLoggedIn }) %>
