<%- include('partials/header', { title: 'Register', css: 'auth.css', isLoggedIn }) %>
<%- include('partials/nav', { isLoggedIn }) %>
<main class="auth-page">
    <div class="container site-container">
        <div class="row g-4 g-lg-5 auth-layout align-items-stretch">
            <section class="col-lg-6 order-lg-2">
                <div class="auth-panel">
                    <p class="auth-kicker">Register</p>
                    <h1 class="auth-title">新しいチーム分析を、<br>ここから始める。</h1>
                    <p class="auth-description">
                        アカウントを作成すると、フルパ構成の勝率、ロール別傾向、
                        マップ相性、最近の流れをチーム単位で見られるようになります。
                    </p>

                    <form action="/register" method="POST" class="auth-form">
                        <div class="mb-3">
                            <label for="register-username" class="auth-label">ユーザー名</label>
                            <input id="register-username" name="username" type="text" class="form-control auth-input" placeholder="ユーザー名を入力" required>
                        </div>

                        <div class="mb-4">
                            <label for="register-password" class="auth-label">パスワード</label>
                            <input id="register-password" name="password" type="password" class="form-control auth-input" placeholder="パスワードを入力" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 auth-submit">新規登録する</button>
                    </form>

                    <p class="auth-link-note mt-4">
                        すでにアカウントがある場合は <a href="/login">ログイン</a> してください。
                    </p>
                </div>
            </section>

            <aside class="col-lg-6 order-lg-1">
                <div class="auth-aside">
                    <div>
                        <p class="auth-aside-kicker">Product Start</p>
                        <h2 class="auth-aside-title">個人ではなく、<br>チームで勝つために。</h2>
                        <p class="auth-aside-text">
                            FullStats は、なんとなくの印象を数字へ変えるための分析ツールです。
                            最初の登録から、そのままチーム単位の意思決定へつなげられます。
                        </p>
                    </div>

                    <div class="auth-metrics">
                        <div class="auth-metric">
                            <span>Feature</span>
                            <strong>5 Modules</strong>
                        </div>
                        <div class="auth-metric">
                            <span>Focus</span>
                            <strong>5 Stack</strong>
                        </div>
                        <div class="auth-metric">
                            <span>Decision</span>
                            <strong>Pre Match</strong>
                        </div>
                        <div class="auth-metric">
                            <span>View</span>
                            <strong>Team Based</strong>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</main>
<%- include('partials/footer') %>
