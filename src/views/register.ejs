<%- include('partials/header', { title: 'Register', css: 'home.css', isLoggedIn }) %>
<%- include('partials/nav', { isLoggedIn }) %>
<main class="simple-page">
    <div class="container site-container">
        <section class="row g-3 auth-page-shell">
            <div class="col-lg-7 auth-page-copy">
                <p class="simple-eyebrow">Account</p>
                <h1 class="simple-title">Register</h1>
                <p class="simple-text">
                    Create a new account for the admin pages.
                </p>
            </div>

            <div class="col-lg-5">
            <article class="card shadow-sm border-0 auth-card">
                <form action="/register" method="POST" class="vstack gap-3 auth-form">
                    <div>
                        <label for="register-username" class="form-label auth-label">Username</label>
                        <input id="register-username" name="username" type="text" class="form-control auth-input" placeholder="Username" required>
                    </div>

                    <div>
                        <label for="register-password" class="form-label auth-label">Password</label>
                        <input id="register-password" name="password" type="password" class="form-control auth-input" placeholder="Password" required>
                    </div>

                    <button type="submit" class="btn btn-dark simple-button auth-submit">Register</button>
                </form>

                <p class="auth-note">
                    Already have an account? <a href="/login">Login here</a>.
                </p>
            </article>
            </div>
        </section>
    </div>
</main>
<%- include('partials/footer', { isLoggedIn }) %>
