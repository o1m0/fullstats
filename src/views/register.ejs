<%- include('partials/header', { title: 'Register', css: 'home.css', isLoggedIn }) %>
<%- include('partials/nav', { isLoggedIn }) %>
<main class="home-page home-architect-page auth-architect-page">
    <div class="container site-container">
        <section class="auth-architect-shell">
            <div class="auth-architect-copy">
                <p class="home-architect-lead">New Member</p>
                <h1 class="home-architect-title">新規登録</h1>
                <p class="home-architect-text">
                    FullStats の管理画面を利用するための
                    アカウント情報を登録します。
                </p>
            </div>

            <article class="auth-architect-panel">
                <form action="/register" method="POST" class="auth-architect-form">
                    <div class="auth-architect-field">
                        <label for="register-username" class="auth-architect-label">Username</label>
                        <input id="register-username" name="username" type="text" class="form-control auth-architect-input" placeholder="Username" required>
                    </div>

                    <div class="auth-architect-field">
                        <label for="register-password" class="auth-architect-label">Password</label>
                        <input id="register-password" name="password" type="password" class="form-control auth-architect-input" placeholder="Password" required>
                    </div>

                    <div class="auth-architect-actions">
                        <button type="submit" class="btn home-architect-primary">Register</button>
                        <span class="home-architect-status">Setup</span>
                    </div>
                </form>

                <p class="auth-architect-note">
                    すでにアカウントをお持ちの場合は、<a href="/login">ログイン</a>してください。
                </p>
            </article>
        </section>
    </div>
</main>
<%- include('partials/footer', { isLoggedIn }) %>
