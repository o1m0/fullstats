<%- include('partials/header', { title: 'Login', css: 'home.css', isLoggedIn }) %>
<%- include('partials/nav', { isLoggedIn }) %>
<main class="simple-page">
    <div class="container site-container">
        <section class="row g-3 auth-page-shell">
            <div class="col-lg-7 auth-page-copy">
                <p class="simple-eyebrow">Account</p>
                <h1 class="simple-title">Login</h1>
                <p class="simple-text">
                    Sign in to open the admin pages.
                </p>
            </div>

            <div class="col-lg-5">
            <article class="card shadow-sm border-0 auth-card">
                <% if (flash) { %>
                    <div class="alert alert-danger auth-alert" role="alert">
                        <strong><%= flash.message %></strong>
                        <% if (sessionData) { %>
                            <pre class="auth-session"><%= sessionData %></pre>
                        <% } %>
                    </div>
                <% } %>

                <form action="/login" method="POST" class="vstack gap-3 auth-form">
                    <div>
                        <label for="login-username" class="form-label auth-label">Username</label>
                        <input id="login-username" name="username" type="text" class="form-control auth-input" placeholder="Username" required>
                    </div>

                    <div>
                        <label for="login-password" class="form-label auth-label">Password</label>
                        <input id="login-password" name="password" type="password" class="form-control auth-input" placeholder="Password" required>
                    </div>

                    <button type="submit" class="btn btn-dark simple-button auth-submit">Login</button>
                </form>

                <p class="auth-note">
                    Need an account? <a href="/register">Register here</a>.
                </p>
            </article>
            </div>
        </section>
    </div>
</main>
<%- include('partials/footer', { isLoggedIn }) %>
