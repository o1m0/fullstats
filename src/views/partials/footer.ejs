                    <a href="/login">ログイン</a>
                    <a href="/register">新規登録</a>
                <% } %>
            </div>
            <p class="footer-copy">&copy; 2026 FullStats</p>
        </div>
    </div>
</footer>
<script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
