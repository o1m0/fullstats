<footer class="site-footer" id="footer">
    <div class="container site-container">
        <div class="site-footer-inner d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between gap-3">
            <p class="site-footer-copy">FullStats simple admin layout.</p>
            <div class="site-footer-links d-flex flex-wrap gap-3">
                <a href="/">Home</a>
                <a href="/tasks">Tasks</a>
                <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
                    <span>Logged in</span>
                <% } else { %>
                    <a href="/login">Login</a>
                    <a href="/register">Register</a>
                <% } %>
            </div>
        </div>
    </div>
</footer>
<script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
<% if (typeof js !== 'undefined' && js) { %>
<script src="/js/<%= js %>"></script>
<% } %>
</body>
</html>
