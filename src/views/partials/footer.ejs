    <div class="container site-container">
        <div class="footer-bar">
            <div class="footer-mark">
                <span class="footer-badge">Team Control Panel</span>
                <a href="/" class="footer-logo">FullStats</a>
            </div>
            <div class="footer-links">
                <a href="/">ホーム</a>
                <a href="/tasks">タスク</a>
