<header class="site-header">
    <nav class="navbar navbar-expand-lg site-navbar" id="themeNavbar">
        <div class="container site-container">
            <a class="navbar-brand d-flex align-items-center gap-3" href="/">
                <span class="brand-logo">FS</span>
                <span class="brand-copy d-flex flex-column">
                    <strong>FullStats</strong>
                    <small>Full Party Intelligence</small>
                </span>
            </a>

            <button
                class="navbar-toggler site-navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#siteNavMenu"
                aria-controls="siteNavMenu"
                aria-expanded="false"
                aria-label="Toggle navigation"
            >
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="siteNavMenu">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">
                    <li class="nav-item">
                        <a class="nav-link site-nav-link" href="/">Overview</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link site-nav-link" href="#modules">Modules</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link site-nav-link" href="#footer">About</a>
                    </li>
                </ul>

                <div class="d-lg-flex align-items-center gap-3 ms-lg-4 pt-3 pt-lg-0 nav-meta">
                    <span class="nav-status d-none d-lg-inline">Built for coordinated 5-stack teams</span>
                    <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
                        <form action="/logout" method="POST" class="nav-auth-form">
                            <button type="submit" class="btn site-login-btn">Logout</button>
                        </form>
                    <% } else { %>
                        <a href="/login" class="btn site-login-btn">Log In</a>
                        <a href="/register" class="btn site-register-btn">Sign Up</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>
</header>
