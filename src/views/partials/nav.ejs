<header class="site-header">
    <div class="site-navbar">
        <div class="container site-container site-header-inner">
            <a class="site-brand" href="/">
                <span class="brand-logo">FS</span>
                <span class="brand-copy">
                    <strong>FullStats</strong>
                    <small>Team Control Panel</small>
                </span>
            </a>

            <nav class="site-primary-nav" aria-label="Primary">
                <a class="site-nav-link" href="/">ホーム</a>
                <a class="site-nav-link" href="/tasks">タスク</a>
            </nav>

            <div class="site-header-actions">
                <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
                    <form action="/logout" method="POST" class="nav-auth-form">
                        <button type="submit" class="btn site-login-btn">ログアウト</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="btn site-login-btn">ログイン</a>
                    <a href="/register" class="btn site-register-btn">新規登録</a>
                <% } %>
            </div>
        </div>
    </div>
</header>
